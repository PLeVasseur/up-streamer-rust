{
  up_streamer_config: {
    message_queue_size: 32,
  },
  usubscription_config: {
    file_path: "subscription_data.json",
  },
  endpoints: [
    {
      name: "zenoh",
      authority: "authority-b",
      transport: "zenoh_owned",
      zenoh_config_file: "ZENOH_CONFIG.json5",
      forwarding: ["mqtt"],
    },
    {
      name: "mqtt",
      authority: "authority-a",
      transport: "mqtt5_owned",
      mqtt_broker_uri: "mqtt://localhost:1883",
      forwarding: ["zenoh"],
    },
  ],
}
